{
  "target": "https://api.example.com",
  "authentication": {
    "type": "bearer",
    "token": "REPLACE_WITH_YOUR_API_TOKEN"
  },
  "apiDiscovery": {
    "enabled": true,
    "paths": ["/openapi.json", "/v3/api-docs", "/swagger.json"]
  },
  "nuclei": {
    "severities": ["medium", "high", "critical"],
    "templates": ["cves", "exposures", "misconfiguration"]
  },
  "reporting": {
    "outputDir": "./output",
    "formats": ["html", "json", "sarif"],
    "branding": {
      "companyName": "Example Corp",
      "primaryColor": "#22c55e"
    }
  },
  "failOn": "critical"
}
