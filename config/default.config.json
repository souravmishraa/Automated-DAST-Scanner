{
  "target": null,
  "authentication": {
    "type": "none",
    "username": null,
    "password": null,
    "token": null,
    "apiKeyHeader": "X-API-Key",
    "apiKeyValue": null,
    "loginUrl": null,
    "usernameField": null,
    "passwordField": null,
    "cookie": null
  },
  "crawler": {
    "katana": {
      "depth": 3,
      "jsCrawl": true,
      "formExtraction": true,
      "concurrency": 10,
      "timeoutSeconds": 120,
      "maxPages": 500,
      "headless": false,
      "rateLimit": 150
    }
  },
  "apiDiscovery": {
    "enabled": true,
    "paths": [
      "/swagger.json",
      "/openapi.json",
      "/api-docs",
      "/v2/api-docs",
      "/v3/api-docs",
      "/swagger/v1/swagger.json",
      "/.well-known/openapi.json"
    ]
  },
  "zap": {
    "mode": "docker",
    "dockerImage": "zaproxy/zap-stable",
    "passiveScan": true,
    "activeScan": true,
    "ajaxSpider": false,
    "spiderMaxDurationMinutes": 10,
    "activeScanMaxDurationMinutes": 90,
    "contextName": "security-framework-context",
    "activeScanPolicy": {
      "defaultStrength": "high",
      "defaultThreshold": "low",
      "focusRules": [
        {"id": 40018, "name": "SQL Injection", "strength": "high", "threshold": "low"},
        {"id": 40019, "name": "SQL Injection - MySQL (Time Based)", "strength": "high", "threshold": "low"},
        {"id": 40021, "name": "SQL Injection - Oracle (Time Based)", "strength": "high", "threshold": "low"},
        {"id": 40022, "name": "SQL Injection - PostgreSQL (Time Based)", "strength": "high", "threshold": "low"},
        {"id": 40012, "name": "Cross Site Scripting (Reflected)", "strength": "high", "threshold": "low"},
        {"id": 40014, "name": "Cross Site Scripting (Persistent) - Attack", "strength": "high", "threshold": "low"},
        {"id": 40016, "name": "Cross Site Scripting (Persistent) - Prime", "strength": "high", "threshold": "low"},
        {"id": 40017, "name": "Cross Site Scripting (Persistent) - Spider", "strength": "high", "threshold": "low"},
        {"id": 40026, "name": "Cross Site Scripting (DOM Based)", "strength": "high", "threshold": "low"},
        {"id": 6, "name": "Path Traversal", "strength": "high", "threshold": "low"},
        {"id": 90020, "name": "Remote OS Command Injection", "strength": "high", "threshold": "low"},
        {"id": 90037, "name": "Remote OS Command Injection (Time Based)", "strength": "high", "threshold": "low"},
        {"id": 90023, "name": "XML External Entity Attack", "strength": "high", "threshold": "low"}
      ]
    }
  },
  "nuclei": {
    "severities": ["info", "low", "medium", "high", "critical"],
    "templates": ["cves", "vulnerabilities", "exposures", "misconfiguration", "default-logins"],
    "rateLimit": 150,
    "concurrency": 25,
    "timeoutSeconds": 900
  },
  "reporting": {
    "outputDir": "./output",
    "formats": ["html", "json", "sarif"],
    "branding": {
      "companyName": "Security Framework",
      "logoUrl": null,
      "primaryColor": "#6366f1"
    }
  },
  "failOn": "critical",
  "logLevel": "info"
}
